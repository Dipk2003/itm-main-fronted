files:
  "/etc/nginx/conf.d/https-redirect.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # HTTPS redirect configuration for Indian Trade Mart
      server {
          listen 80;
          server_name *.indiantrademart.com indiantrademart.com;
          
          # Health check should not redirect
          location /health {
              proxy_pass http://localhost:3000/health;
              access_log off;
          }
          
          # ALB health checks
          location /actuator/health {
              proxy_pass http://localhost:3000/health;
              access_log off;
          }
          
          # Redirect HTTP to HTTPS for all other requests
          location / {
              if ($http_x_forwarded_proto != 'https') {
                  return 301 https://$host$request_uri;
              }
              
              proxy_pass http://localhost:3000;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
          }
      }

option_settings:
  aws:elbv2:listener:80:
    Protocol: HTTP
    Rules: |
      [{
        "Priority": 1,
        "Conditions": [{
          "Field": "http-header",
          "HttpHeaderConfig": {
            "HttpHeaderName": "X-Forwarded-Proto",
            "Values": ["http"]
          }
        }],
        "Actions": [{
          "Type": "redirect",
          "RedirectConfig": {
            "Protocol": "HTTPS",
            "Port": "443",
            "StatusCode": "HTTP_301"
          }
        }]
      }]
  aws:elbv2:listener:443:
    Protocol: HTTPS
    SSLCertificateArns: arn:aws:acm:us-east-1:YOUR_ACCOUNT_ID:certificate/YOUR_CERTIFICATE_ID

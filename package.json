{
  "name": "b2b-marketplace-frontend",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:fast": "set NODE_OPTIONS=--max-old-space-size=8192 && next dev --turbo",
    "build": "next build",
    "build:production": "NODE_ENV=production next build",
    "start": "next start",
    "start:production": "NODE_ENV=production next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf .next dist build node_modules/.cache",
    "prebuild": "npm run clean",
    "postbuild": "echo \"Build completed successfully!\"",
    "dev:optimized": "set NODE_ENV=development && set NEXT_TELEMETRY_DISABLED=1 && next dev",
    "build:fast": "set SKIP_ENV_VALIDATION=true && next build",
    "analyze": "ANALYZE=true npm run build",
    "clean:full": "rimraf .next dist build node_modules",
    "fresh-install": "npm run clean:full && npm install",
    "performance-check": "node performance-optimization.js",
    "lint:warn": "next lint --max-warnings 1000",
    "lint:fix-auto": "next lint --fix --max-warnings 1000",
    "type-check:lenient": "tsc --noEmit --skipLibCheck --allowJs",
    "dev:no-lint": "DISABLE_ESLINT_PLUGIN=true npm run dev",
    "fix-bugs": "node fix-frontend-bugs.js",
    "build:ignore-errors": "set DISABLE_ESLINT_PLUGIN=true && npm run build",
    "dev:ignore-errors": "set DISABLE_ESLINT_PLUGIN=true && npm run dev",
    "start:prod": "NODE_ENV=production npm start"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.8.2",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "axios": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.5",
    "lucide-react": "^0.525.0",
    "next": "15.3.5",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "recharts": "^3.1.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chalk": "^5.5.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "rimraf": "^5.0.10",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "webpack-bundle-analyzer": "^4.10.1"
  }
}

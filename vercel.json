{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://indianmart.ap-south-1.elasticbeanstalk.com/api/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://indianmart.ap-south-1.elasticbeanstalk.com"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "https://indianmart.ap-south-1.elasticbeanstalk.com"
    }
  }
}
